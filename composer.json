    "version": "0.0.1",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "orchestra/testbench": "*",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "larastan/larastan": "^3.0"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
