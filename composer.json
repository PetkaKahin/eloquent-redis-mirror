{
    "name": "petkakahin/eloquent-redis-mirror",
    "description": "Mirror Laravel Eloquent models to Redis for fast read access with automatic write-through synchronization",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "eloquent",
        "redis",
        "cache",
        "mirror",
        "performance"
    ],
    "homepage": "https://github.com/PetkaKahin/eloquent-redis-mirror",
    "support": {
        "issues": "https://github.com/PetkaKahin/eloquent-redis-mirror/issues",
        "source": "https://github.com/PetkaKahin/eloquent-redis-mirror",
        "telegram": "https://t.me/CuberLocksmith"
    },
    "authors": [
        {
            "name": "Stanislav Gradov",
            "email": "gradik.st@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/redis": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "*",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "larastan/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "PetkaKahin\\EloquentRedisMirror\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PetkaKahin\\EloquentRedisMirror\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PetkaKahin\\EloquentRedisMirror\\Providers\\RedisMirrorServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
