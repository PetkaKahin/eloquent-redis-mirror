includes:
    - vendor/larastan/larastan/extension.neon

parameters:
    paths:
        - src
    level: max
    ignoreErrors:
        # Trait is used by models in application code, PHPStan can't detect external usage
        - identifier: trait.unused

        # Redis pipeline callback receives a pipe object that PHPStan can't type
        - identifier: method.nonObject
          path: src/Repository/RedisRepository.php

        # Eloquent Model::getKey()/getAttribute() returns mixed by design
        - identifier: binaryOp.invalid
          path: src/Builder/RedisBuilder.php
        - identifier: cast.string
          path: src/Builder/RedisBuilder.php
        - identifier: offsetAccess.invalidOffset
          path: src/Builder/RedisBuilder.php
        - identifier: binaryOp.invalid
          path: src/Listeners/SyncRedisHash.php
        - identifier: cast.string
          path: src/Listeners/SyncRedisHash.php
        - identifier: cast.string
          path: src/Listeners/SyncRedisPivot.php


        # parent::sync/toggle return types are loosely typed in Laravel
        - identifier: return.type
          path: src/Relations/RedisBelongsToMany.php
        - identifier: argument.type
          path: src/Relations/RedisBelongsToMany.php

        # Eloquent Model::getKey() returns mixed — used in string ops in EagerLoad
        - identifier: binaryOp.invalid
          path: src/Builder/EagerLoad/BelongsToManyLoader.php
        - identifier: cast.string
          path: src/Builder/EagerLoad/BelongsToManyLoader.php
        - identifier: binaryOp.invalid
          path: src/Builder/EagerLoad/HasManyLoader.php
        - identifier: cast.string
          path: src/Builder/EagerLoad/HasManyLoader.php
        - identifier: cast.string
          path: src/Builder/EagerLoad/FetchesRelatedModels.php

        # array_unique expects string-castable, Model::getKey() returns mixed
        - identifier: argument.type
          path: src/Builder/EagerLoad/BelongsToLoader.php
        - identifier: argument.type
          path: src/Builder/EagerLoad/BelongsToManyLoader.php
        - identifier: argument.type
          path: src/Builder/EagerLoad/HasManyLoader.php

        # method_exists check is always true per PHPDoc but keeps runtime safety
        - identifier: function.alreadyNarrowedType
          path: src/Builder/EagerLoad/FetchesRelatedModels.php

        # ResolvesRedisRelations getAttribute() returns mixed
        - identifier: cast.string
          path: src/Concerns/ResolvesRedisRelations.php

        # array_values on a known list is harmless
        - identifier: arrayValues.list
